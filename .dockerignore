# Keep the build context small and reproducible
node_modules
dist
.git
.github
# Maven output only — NOT a bare "target" (the source package
# com.spiramindscape.backend.target must stay in the build context).
backend/target
*.log
.vscode
.idea
.DS_Store
tests-e2e
# Root-level book folder. In .dockerignore an unanchored "grow" only matches
# the root anyway, but keep it explicit so it's never copied into a pattern
# with gitignore semantics (see .gcloudignore, where that broke the deploy).
/grow
docs
specs
**/*.md
